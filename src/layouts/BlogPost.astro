---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";

import BaseLayout from "./Base.astro";
import "katex/dist/katex.min.css";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
	}}
>
	<article class="grow break-words" data-pagefind-body>
		<div id="blog-hero" class="mb-12"><Masthead content={post} readingTime={readingTime} /></div>
		<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
			{!!headings.length && <TOC headings={headings} />}
			<div
				class="prose prose-sm prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-muted prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none"
			>
				<slot />
				<WebMentions />
			</div>
		</div>
	</article>
	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>

<script>
	function codeSource(pre: HTMLElement) {
		const lines = Array.from(pre.querySelectorAll<HTMLElement>(".ec-line .code"));
		if (lines.length) return lines.map((line) => line.textContent ?? "").join("\n");
		return pre.querySelector("code")?.textContent ?? pre.textContent ?? "";
	}

	async function renderMath() {
		const inlineNodes = Array.from(
			document.querySelectorAll<HTMLElement>("code.math-inline"),
		);
		const displayNodes = [
			...new Set(
				Array.from(
					document.querySelectorAll<HTMLElement>(
						'pre[data-language="math"], pre > code.math-display',
					),
				).map((node) => (node.tagName === "PRE" ? node : (node.parentElement as HTMLElement))),
			),
		];
		if (!inlineNodes.length && !displayNodes.length) return;

		const { default: katex } = await import("katex");
		for (const node of inlineNodes) {
			const container = document.createElement("span");
			container.className = "math-inline";
			katex.render(node.textContent ?? "", container, {
				displayMode: false,
				strict: "warn",
				throwOnError: false,
			});
			node.replaceWith(container);
		}

		for (const pre of displayNodes) {
			const container = document.createElement("div");
			container.className = "math-block";
			katex.render(codeSource(pre), container, {
				displayMode: true,
				strict: "warn",
				throwOnError: false,
			});
			const target = pre.closest("figure.expressive-code") ?? pre;
			target.replaceWith(container);
		}
	}

	async function renderMermaid() {
		const blocks = [
			...new Set(
				Array.from(
					document.querySelectorAll<HTMLElement>(
						'pre[data-language="mermaid"], pre > code.language-mermaid',
					),
				).map((node) => (node.tagName === "PRE" ? node : (node.parentElement as HTMLElement))),
			),
		];
		if (!blocks.length) return;

		const { default: mermaid } = await import("mermaid");
		mermaid.initialize({
			securityLevel: "strict",
			startOnLoad: false,
			theme: document.documentElement.dataset.theme === "dark" ? "dark" : "default",
		});

		for (const [index, pre] of blocks.entries()) {
			const source = codeSource(pre);
			const container = document.createElement("div");
			container.className = "mermaid-diagram";
			try {
				const { svg } = await mermaid.render(`mermaid-${Date.now()}-${index}`, source);
				container.innerHTML = svg;
				const target = pre.closest("figure.expressive-code") ?? pre;
				target.replaceWith(container);
			} catch (error) {
				container.classList.add("mermaid-error");
				container.textContent = "Unable to render this Mermaid diagram.";
				console.error(error);
			}
		}
	}

	function enhanceArticle() {
		void renderMath();
		void renderMermaid();
	}

	enhanceArticle();
	document.addEventListener("astro:page-load", enhanceArticle);
</script>
